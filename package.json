{
  "name": "playwright-typescript-cucumber-framework",
  "version": "1.0.0",
  "description": "Playwright + TypeScript framework for POM, Cucumber, Allure, parallel, and cross-browser testing",
  "private": true,
  "scripts": {
    "clean": "rimraf reports visual/actual visual/diff visual/reports",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:pom",
    "test:pom": "playwright test tests/e2e --grep @pom --project=chromium",
    "test:pom:cross-browser": "playwright test tests/e2e --grep @pom --project=chromium --project=firefox --project=webkit",
    "test:cucumber": "cucumber-js --config cucumber.js",
    "test:cucumber:feature": "node scripts/run-cucumber-feature.js",
    "report:playwright": "playwright show-report reports/playwright/html",
    "report:allure": "allure generate reports/allure-results --clean -o reports/allure-report",
    "report:allure:open": "npx allure serve reports/allure-results",
    "demo:showcase": "npm run clean && npm run test:pom && npm run test:cucumber && npm run report:allure"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.6.0",
    "@types/pngjs": "^6.0.5",
    "allure-commandline": "^2.34.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-js-commons": "^3.4.1",
    "allure-playwright": "^3.4.1",
    "dotenv": "^17.2.3",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
